# ============ 基础配置 ============
APP_ENV=dev
DEBUG=true
PROJECT_NAME=Orbit
API_V1_STR=/api/v1

# ============ 数据库（PostgreSQL 生产 / SQLite 开发）============
# 开发用 SQLite（零依赖启动）；生产切 PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./data/graph.db
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/orbit

# ============ Redis ============
REDIS_URL=redis://localhost:6379/0

# ============ LiteLLM 网关 ============
# P0-16 (Issue#126): 占位符防直接复制使用
# P1-3 (PR#131): REPLACE_WITH_YOUR_KEY 无 sk- 前缀——避免 GitHub Secret Scanning 误报
LITELLM_MASTER_KEY=REPLACE_WITH_YOUR_KEY
LITELLM_PROXY_URL=http://localhost:4000

# ============ 模型 API Keys（Mock 阶段用占位，禁止填真实 key）============
OPENAI_API_KEY=sk-dummy
DEEPSEEK_API_KEY=sk-dummy

# ============ 沙箱 ============
DOCKER_HOST=unix:///var/run/docker.sock
SANDBOX_TIMEOUT_SECONDS=30