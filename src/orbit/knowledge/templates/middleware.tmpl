from __future__ import annotations

from typing import Awaitable, Callable

from fastapi import FastAPI, Request, Response
from starlette.middleware.base import BaseHTTPMiddleware


class {{middleware_name}}Middleware(BaseHTTPMiddleware):
    """{{middleware_name}}拦截器.

    在请求处理前后注入 {{description}} 逻辑。
    """

    async def dispatch(
        self,
        request: Request,
        call_next: Callable[[Request], Awaitable[Response]],
    ) -> Response:
        """请求前处理."""
        # TODO: 前置逻辑（鉴权/日志/计时等）
        # 示例：request.state.start_time = time.time()

        response = await call_next(request)

        """响应后处理."""
        # TODO: 后置逻辑（审计/缓存/Header 注入等）
        # 示例：response.headers["X-Process-Time"] = str(elapsed)

        return response


def register_{{middleware_name}}_middleware(app: FastAPI) -> None:
    """注册中间件到应用实例。"""
    app.add_middleware({{middleware_name}}Middleware)
