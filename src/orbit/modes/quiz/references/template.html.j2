<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>改动理解测验 — {{ task_id }}</title>
<style>
  :root { --bg: #0d1117; --fg: #c9d1d9; --accent: #58a6ff; --green: #3fb950; --red: #f85149; --border: #30363d; --card-bg: #161b22; --muted: #8b949e; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, "Noto Sans SC", sans-serif; background: var(--bg); color: var(--fg); line-height: 1.7; max-width: 800px; margin: 0 auto; padding: 2rem 1.5rem; }
  h1 { font-size: 1.6rem; border-bottom: 2px solid var(--accent); padding-bottom: 0.5rem; margin-bottom: 1rem; }
  .question { background: var(--card-bg); border: 1px solid var(--border); border-radius: 8px; padding: 1.2rem; margin: 1rem 0; }
  .question h3 { font-size: 1rem; margin-bottom: 0.8rem; }
  .options { display: flex; gap: 1rem; }
  .option { padding: 0.5rem 1.5rem; border: 1px solid var(--border); border-radius: 6px; cursor: pointer; background: transparent; color: var(--fg); font-size: 0.95rem; }
  .option:hover { border-color: var(--accent); }
  .option.selected-true { border-color: var(--green); background: rgba(63,185,80,0.15); }
  .option.selected-false { border-color: var(--red); background: rgba(248,81,73,0.15); }
  .explanation { margin-top: 0.8rem; padding: 0.8rem; border-radius: 6px; font-size: 0.9rem; display: none; }
  .explanation.correct { background: rgba(63,185,80,0.1); border: 1px solid var(--green); color: var(--green); }
  .explanation.incorrect { background: rgba(248,81,73,0.1); border: 1px solid var(--red); color: var(--red); }
  .explanation.visible { display: block; }
  .summary { text-align: center; margin: 2rem 0; padding: 1.5rem; border-radius: 8px; display: none; }
  .summary.visible { display: block; }
  .summary.passed { background: rgba(63,185,80,0.1); border: 2px solid var(--green); }
  .summary.failed { background: rgba(248,81,73,0.1); border: 2px solid var(--red); }
  .score { font-size: 2rem; font-weight: 700; }
  .meta { color: var(--muted); font-size: 0.85rem; margin: 0.5rem 0; }
  .btn { display: inline-block; padding: 0.6rem 1.5rem; border-radius: 6px; border: none; cursor: pointer; font-size: 1rem; font-weight: 600; }
  .btn-primary { background: var(--accent); color: #000; }
  .btn-secondary { background: var(--border); color: var(--fg); }
  .source-files { font-size: 0.8rem; color: var(--muted); margin-top: 0.3rem; }
</style>
</head>
<body>

<h1>📝 改动理解测验</h1>
<p class="meta">任务: {{ task_id }} | 生成时间: {{ generated_at }} | 改动文件: {{ file_count }} 个</p>
<p class="meta" style="margin-bottom:1.5rem;">规则: 5 道判断题，全部答对方可标记任务完成。这是 Fable 5 方法论的最后一道防线——<em>"不理解每一处改动，就不配合并。"</em></p>

<div id="quiz-container">
  {% for q in questions %}
  <div class="question" id="q-{{ q.id }}">
    <h3>第 {{ q.id }} 题 <span style="color:var(--muted);font-weight:400">— {{ q.category }}</span></h3>
    <p>{{ q.statement }}</p>
    <div class="source-files">涉及: {{ q.source_files | join(", ") }}</div>
    <div class="options" style="margin-top:0.8rem;">
      <button class="option" onclick="answer({{ q.id }}, true, this)">✅ 正确</button>
      <button class="option" onclick="answer({{ q.id }}, false, this)">❌ 错误</button>
    </div>
    <div class="explanation" id="exp-{{ q.id }}">{{ q.explanation }}</div>
  </div>
  {% endfor %}
</div>

<div class="summary" id="summary">
  <div class="score" id="score-text">0/5</div>
  <p id="summary-msg"></p>
  <button class="btn btn-primary" id="retry-btn" style="display:none" onclick="retry()">重新作答</button>
</div>

<script>
  const answers = {};
  const correctAnswers = {{ correct_answers | tojson }};
  let submitted = false;

  function answer(qid, userAnswer, btn) {
    if (submitted) return;
    // Toggle selection
    const container = document.getElementById('q-' + qid);
    const allOpts = container.querySelectorAll('.option');
    allOpts.forEach(o => { o.classList.remove('selected-true', 'selected-false'); });
    btn.classList.add(userAnswer ? 'selected-true' : 'selected-false');
    answers[qid] = userAnswer;
    checkAllAnswered();
  }

  function checkAllAnswered() {
    if (Object.keys(answers).length === 5) {
      submit();
    }
  }

  function submit() {
    submitted = true;
    let correct = 0;
    for (let i = 1; i <= 5; i++) {
      const exp = document.getElementById('exp-' + i);
      if (answers[i] === correctAnswers[i]) {
        exp.classList.add('correct', 'visible');
        correct++;
      } else {
        exp.classList.add('incorrect', 'visible');
      }
    }
    const summary = document.getElementById('summary');
    summary.classList.add('visible');
    document.getElementById('score-text').textContent = correct + '/5';
    if (correct === 5) {
      summary.classList.add('passed');
      document.getElementById('summary-msg').textContent = '🎉 全部正确！你已理解本次改动的每一处变更。可以标记任务完成。';
    } else {
      summary.classList.add('failed');
      document.getElementById('summary-msg').textContent = '❌ ' + (5 - correct) + ' 题有误。请查看红色解释，理解错误后重试。';
      document.getElementById('retry-btn').style.display = 'inline-block';
    }
  }

  function retry() {
    submitted = false;
    Object.keys(answers).forEach(k => delete answers[k]);
    document.querySelectorAll('.option').forEach(o => { o.classList.remove('selected-true', 'selected-false'); });
    document.querySelectorAll('.explanation').forEach(e => { e.classList.remove('visible', 'correct', 'incorrect'); });
    const summary = document.getElementById('summary');
    summary.classList.remove('visible', 'passed', 'failed');
    document.getElementById('retry-btn').style.display = 'none';
  }
</script>

</body>
</html>
